{
  "name": "root",
  "private": true,
  "license": "MIT",
  "npmClient": "yarn",
  "usingWorkspances": true,
  "workspaces": {
    "packages": [
      "packages/*"
    ]
  },
  "scripts": {
    "dev": "yarn workspaces run dev",
    "dev:react-admin": "yarn workspace react-admin run dev",
    "dev:react-client": "yarn workspace react-client run dev",
    "dev:server": "yarn workspace server run dev",
    "dev:admin-server": "concurrently \"yarn:dev:react-admin\" \"yarn:dev:server\"",
    "dev:client-server": "concurrently \"yarn:dev:react-client\" \"yarn:dev:server\""
  },
  "devDependencies": {
    "@umijs/fabric": "^2.10.2",
    "concurrently": "^7.0.0",
    "eslint": "^7.1.0",
    "prettier": "^2.5.1",
    "stylelint": "^14.5.3",
    "typescript": "^4.6.2"
  },
  "dependencies": {}
}
