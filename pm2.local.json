{
  "apps": [
    {
      "name": "izoro-api",
      "script": "cd /packages/server && nest start",
      "cwd": "/packages/server/dist",
      "exec_mode": "fork",
      "max_memory_restart": "1G",
      "autorestart": true,
      "env": {}
    },
    {
      "name": "izoro-blog",
      "script": "cd /packages/react-client && next start -p 3001",
      "cwd": "/packages/react-client/.next",
      "exec_mode": "cluster",
      "instance": 2,
      "max_memory_restart": "1.5G",
      "autorestart": true,
      "env": {}
    }
  ]
}
