{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "es2017",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./src",
    "incremental": true,
    "paths": {
      "@": ["./"],
      "@/*": ["./*"],
      "@common": ["./common"],
      "@common/*": ["./common/*"],
      "@decorators": ["./decorators"],
      "@decorators/*": ["./decorators/*"],
      "@interfaces/*": ["./interfaces/*"],
      "@modules": ["./src/modules"],
      "@modules/*": ["./src/modules/*"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
