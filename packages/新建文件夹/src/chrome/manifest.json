{
	"manifest_version": 2,
	"name": "vue chrome插件基础框架",
	"description": "基于vue开发的chrome插件",
	"version": "1.0.0",
	"browser_action": {
		"default_title": "vue chrome插件基础框架",
		"default_icon": "assets/logo.png"
		// "default_popup": "popup.html"
	},
	"permissions": [
		"webRequestBlocking",
		"notifications",
		"tabs",
		"webRequest",
		"http://*/",
		"https://*/",
		"<all_urls>",
		"storage",
		"activeTab"
	],
	"background": {
		"scripts": ["js/background.js"]
	},
	"icons": {
		"16": "assets/logo.png",
		"48": "assets/logo.png",
		"128": "assets/logo.png"
	},
	"content_security_policy": "script-src 'self' 'unsafe-eval'; object-src 'self'",
	"content_scripts": [
		{
			"matches": [
				// "file:///Users/qian/Desktop/work/browser-extension/*",
				// "https://offer.ebay.com.au/ws/eBayISAPI.dll?*",
				// "https://buyin.jinritemai.com/*"
				"<all_urls>"
				// "https://*.baidu.com/*"
			],
			"css": [
				// "css/content.css"
				"css/inject.css"
			],
			"js": [
				"js/content.js"
			],
			"run_at": "document_end"
		}
	],
	"web_accessible_resources": ["fonts/*", "js/inject.js"]
}